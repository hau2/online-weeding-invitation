# Supabase (used by apps/api)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Auth (used by apps/api)
JWT_EXPIRES_IN=7d

# Email (used by apps/api for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=no-reply@thiepcoionline.vn

# App URLs
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000

# Next.js (used by apps/web — NEXT_PUBLIC_ prefix for browser-exposed vars only)
NEXT_PUBLIC_API_URL=http://localhost:4000
# SUPABASE_JWT_SECRET is NOT prefixed NEXT_PUBLIC_ — used only by Edge middleware
SUPABASE_JWT_SECRET=your-jwt-secret
